{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sports Window",
  "version": "1.0.0",
  "identifier": "com.mika.sports-window",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sports Window",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://a.espncdn.com data:; connect-src 'self' https://site.api.espn.com https://site.web.api.espn.com https://statsapi.mlb.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/seara182/sports-window/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEzMzY5NTIzRkUyNjlCMTkKUldRWm15YitJNVUyRTlZTzZZR3VkaEs2aUxJK2FqNkM5bHJFVFA1bVBUNFE5bTY3L2FBL2o4NE8K"
    }
  }
}
